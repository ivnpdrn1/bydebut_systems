function CommentSection() {
  const [comments, setComments] = useState([]);
  const [input, setInput] = useState("");

  const addComment = () => {
    if (!input.trim()) return;
    setComments([
      ...comments,
      {
        id: Date.now(),
        text: input,
      },
    ]);
    setInput("");
  };

  return (
    <Card className="rounded-3xl border-stone-200 bg-white shadow-sm mt-6">
      <CardHeader>
        <CardTitle className="font-serif text-2xl">Community Discussion</CardTitle>
        <CardDescription>Evaluate, critique, and expand this variation.</CardDescription>
      </CardHeader>

      <CardContent className="space-y-4">
        <div className="flex gap-2">
          <Textarea
            value={input}
            onChange={(e) => setInput(e.target.value)}
            placeholder="Write your insight, critique, or extension..."
            className="rounded-2xl"
          />
          <Button onClick={addComment} className="rounded-2xl h-fit">
            Comment
          </Button>
        </div>

        <div className="space-y-3">
          {comments.map((comment) => (
            <div
              key={comment.id}
              className="rounded-2xl bg-stone-50 p-3 text-sm text-stone-700"
            >
              {comment.text}
            </div>
          ))}
        </div>
      </CardContent>
    </Card>
  );
}

